# EcoStock - configuração local recomendada para XAMPP
SECRET_KEY=ecostock-local-key-123
FLASK_DEBUG=True
APP_HOST=127.0.0.1
APP_PORT=8000
SESSION_TIMEOUT_MINUTES=30

# Banco (XAMPP padrão)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ecostock_db

# Admin inicial (criado automaticamente se não existir)
ADMIN_INITIAL_LOGIN=admin
ADMIN_INITIAL_PASSWORD=Admin@123
ADMIN_INITIAL_EMAIL=admin@local
ADMIN_FORCE_RESET_ON_START=False

# E-mail (opcional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
ADMIN_EMAIL=

# Alertas
ALERT_DAYS_CRITICAL=7
ALERT_DAYS_WARNING=15
ALERT_DAYS_NOTICE=30
